{
  "name": "secure-agentic-llm-framework",
  "version": "0.1.0",
  "description": "A production-ready framework for securing agentic LLM systems against prompt injection and data exfiltration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev": "ts-node src/index.ts",
    "example:basic": "ts-node examples/basic_agent.ts",
    "example:attacks": "ts-node examples/attack_scenarios.ts",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "llm",
    "security",
    "prompt-injection",
    "data-exfiltration",
    "agentic-systems"
  ],
  "author": "Andrzej Mycek, Mieszko Cichoń",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.21.0",
    "openai": "^4.51.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
